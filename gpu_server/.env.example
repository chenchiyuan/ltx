CONTROL_PLANE_URL=http://control-plane:8000
CONTROL_PLANE_PUBLIC_URL=http://127.0.0.1:8000
WEB_PORT=80
DISPATCH_INTERVAL_SECONDS=5
DISPATCH_TIMEOUT_SECONDS=10

WORKER_COUNT=5
WORKER_SERVICES=worker-fast-0,worker-fast-1,worker-fast-2,worker-fast-3,worker-vip
GPU_LAYOUT="fast:0;fast:1;fast:2;fast:3;vip:4,5,6,7"
START_GPU_WORKERS=true
ENABLE_MGPU_EXPERIMENTAL=true

APP_DATA_DIR=/opt/ltx/app-data
MODEL_DIR=/opt/ltx/models
STORAGE_DIR=/opt/ltx/storage
LTX_HF_REPO=Lightricks/LTX-2.3
GEMMA_HF_REPO=Comfy-Org/ltx-2
GEMMA_HF_FILE=split_files/text_encoders/gemma_3_12B_it.safetensors

BOOTSTRAP_API_KEY=replace-with-api-key
ADMIN_TOKEN=replace-with-admin-token
WORKER_TOKEN=replace-with-worker-token

STORAGE_BACKEND=local_shared
EXECUTOR_BACKEND=gpu-worker
PUBLIC_BASE_URL=http://localhost:8000

WORKER_STATUS=unhealthy
WORKER_NOT_READY_REASON=T204_ADAPTER_SKELETON
HEARTBEAT_INTERVAL_SECONDS=15
START_COMFYUI=true
COMFYUI_HOST=127.0.0.1
COMFYUI_PORT=8188
WORKER_EXECUTION_BACKEND=comfyui
COMFYUI_POLL_INTERVAL_SECONDS=5
COMFYUI_TIMEOUT_SECONDS=3600
WORKFLOW_PATH=/opt/comfyui/custom_nodes/ComfyUI-LTXVideo/example_workflows/2.3/LTX-2.3_T2V_I2V_Single_Stage_Distilled_Full.json
MGPU_PIPELINE=distilled
MGPU_DISTILLED_CACHE_DIR=/opt/ltx/models/checkpoints
MGPU_GEMMA_CACHE_DIR=/opt/ltx/models/gemma-3-12b-local
MGPU_DISTILLED_CHECKPOINT_PATH=/fp8/ltx-2.3-22b-distilled-fp8.safetensors
MGPU_GEMMA_ROOT=/gemma
MGPU_QUANTIZATION=fp8-scaled-mm
MGPU_OFFLOAD_MODE=none
MGPU_NO_LORA_SWAP=true
MGPU_NO_AUDIO=true
MGPU_DISTRIBUTED_VAE=false
MGPU_VAE_OVERLAP=4
MGPU_NUM_INFERENCE_STEPS=8
MGPU_START_TIMEOUT_SECONDS=3600
MGPU_JOB_TIMEOUT_SECONDS=7200

COMFYUI_REPO=https://github.com/comfyanonymous/ComfyUI.git
COMFYUI_REF=5697b970173bc0c16a05c30d509d0911f2b84822
LTXVIDEO_REPO=https://github.com/Lightricks/ComfyUI-LTXVideo.git
LTXVIDEO_REF=aceeae9635f6d493f2893ba3c411a1c36031788a
RES4LYF_REPO=https://github.com/ClownsharkBatwing/RES4LYF.git
RES4LYF_REF=419de2d7c78f415dde9aa352a7231820ebfc17a4

PYTORCH_INDEX_URL=https://download.pytorch.org/whl/cu128
TORCH_VERSION=2.8.0+cu128
TORCHVISION_VERSION=0.23.0+cu128
TORCHAUDIO_VERSION=2.8.0+cu128
LTX2_REPO=https://github.com/Lightricks/LTX-2.git
LTX2_REF=9377758131b1ffde4b7f766804590a6617bf2ab9
